  @@index([tenantId, status, createdAt])
  @@map("report_exports")
}

model MetricsEvent {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  eventType   String   @map("event_type")
  eventDate   DateTime @map("event_date") @db.Date
  referenceId String?  @map("reference_id")
