# ─────────────────────────────────────────────────────────────────────
# WathiqCare — .env.example
# Copy to .env (root), apps/api/.env, and apps/web/.env.local as needed.
# NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────────────

# ── App URLs ──────────────────────────────────────────────────────────
APP_BASE_URL=https://wathiqcare.com
API_BASE_URL=https://api.wathiqcare.com
NEXT_PUBLIC_API_BASE_URL=https://api.wathiqcare.com

# ── Database ──────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=replace-with-db-password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wathiqcare
# Runtime (app server): pooled Neon URL preferred.
DATABASE_URL_POOLED="postgresql://postgres:replace-with-db-password@localhost:5432/wathiqcare?pgbouncer=true&connection_limit=1"
# Fallback runtime URL if pooled is not provided.
DATABASE_URL="postgresql://postgres:replace-with-db-password@localhost:5432/wathiqcare"
# Migrations only: direct/unpooled connection.
DATABASE_URL_UNPOOLED="postgresql://postgres:replace-with-db-password@localhost:5432/wathiqcare"

POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-db-password
POSTGRES_DB=wathiqcare

# ── Redis / Queue ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Object Storage (S3 or S3-compatible) ─────────────────────────────
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=me-south-1
S3_BUCKET=replace-with-s3-bucket
S3_ACCESS_KEY=replace-with-access-key
S3_SECRET_KEY=replace-with-secret-key

# ── SMS ───────────────────────────────────────────────────────────────
# Provider: taqnyat | unifonic | mock
SMS_PROVIDER=mock
SMS_BASE_URL=https://api.taqnyat.sa
SMS_BEARER_TOKEN=
SMS_SENDER=WathiqCare
SMS_ENABLED=true
SMS_EVIDENCE_ENABLED=false
TAQNYAT_API_KEY=
UNIFONIC_API_KEY=

# Optional SMS Gateway Proxy (preferred when both URL and secret are set).
# When configured, SMS are dispatched through the proxy instead of directly to Taqnyat.
SMS_PROXY_URL=https://sms-proxy.wathiqcare.online
SMS_PROXY_SECRET=
SMS_PROXY_SENDER_NAME=WATHIQID

# ── Email (Microsoft Graph) ───────────────────────────────────────────
MICROSOFT_TENANT_ID=replace-with-microsoft-tenant-id
MICROSOFT_CLIENT_ID=replace-with-microsoft-client-id
MICROSOFT_CLIENT_SECRET=replace-with-microsoft-graph-client-secret
MICROSOFT_SENDER_EMAIL=admin@example.com

# ── Payments ──────────────────────────────────────────────────────────
# Provider: hyperpay | stripe | mock
PAYMENT_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
HYPERPAY_ACCESS_TOKEN=
HYPERPAY_ENTITY_ID=

# ── Security ──────────────────────────────────────────────────────────
# Required: strong random secrets (min 256 bits recommended)
JWT_SECRET_KEY=replace-with-strong-random-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=wathiqcare
# Pepper appended to raw token before sha256 hashing — rotate on full migration only
PUBLIC_LINK_TOKEN_PEPPER=replace-with-strong-random-pepper
OTP_SECRET=replace-with-strong-random-secret
WATHIQ_STEP_UP_SECRET=replace-with-strong-random-secret
SHC_COMPLIANCE_MODULE=false
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Backend proxy (Next.js server-side) ──────────────────────────────
BACKEND_URL=http://localhost:8000
BACKEND_API_BASE_URL=http://localhost:8000

# ── External PDF Renderer ─────────────────────────────────────────────
# Optional isolated Chromium/PDF rendering service.  When both URL and SECRET
# are set, the Next.js server calls the renderer with x-wathiq-internal-secret.
# In production the renderer rejects requests when the secret is missing.
PDF_RENDERER_URL=http://localhost:8080
PDF_RENDERER_SECRET=replace-with-strong-random-secret

# ── Authentication / Local dev helpers ────────────────────────────────
NEXT_PUBLIC_ENABLE_DEV_LOGIN_PREFILL=false
NEXT_PUBLIC_DEV_LOGIN_EMAIL=
NEXT_PUBLIC_DEV_LOGIN_PASSWORD=
ENABLE_INFORMED_CONSENTS=true

# ── Operational seed / release-gate passwords ─────────────────────────
# Required only when running the associated scripts. Must be strong and unique.
DEMO_DEFAULT_PASSWORD=
DEMO_ROTATED_PASSWORD=
PILOT_DEFAULT_PASSWORD=
PILOT_VALIDATION_PASSWORD=
IMC_DOCTOR_PILOT_PASSWORD=IMC@imc2026
VALIDATION_ADMIN_PASSWORD=
RELEASE_GATE_PASSWORD=
RELEASE_GATE_RESET_PASSWORD=
IMC_ADMIN_PASSWORD=
WATHIQCARE_ADMIN_EMAIL=
WATHIQCARE_ADMIN_PASSWORD=
WATHIQCARE_SUPERADMIN_PASSWORD=
WATHIQCARE_PLATFORM_ADMIN_PASSWORD=
DEMO_OWNER_PASSWORD_HASH=
PLATFORM_ADMIN_PASSWORD_HASH=
PLATFORM_SUPERUSER_PASSWORD_HASH=
UAT_PILOT_PASSWORD=
UAT_TEST_PASSWORD=
E2E_JWT_SECRET=
TEST_PASSWORD=

# ── Integration Monitoring Connectors ─────────────────────────────────
# Supported keys: EPIC_EMR, CERNER_MILLENNIUM, LEGACY_SYSTEM, FHIR_INTEGRATION
INTEGRATION_SCHEDULER_ENABLED=true
INTEGRATION_SCHEDULER_POLL_SECONDS=15
INTEGRATION_SCHEDULER_STALE_RUN_SECONDS=600

# Scheduler alerting and notifications
INTEGRATION_ALERTS_ENABLED=true
INTEGRATION_ALERT_COOLDOWN_SECONDS=900
INTEGRATION_ALERT_REPEATED_FAILURE_THRESHOLD=3
INTEGRATION_ALERT_EMAIL_TO=
INTEGRATION_ALERT_WEBHOOK_URL=
INTEGRATION_ALERT_WEBHOOK_TIMEOUT_SECONDS=10

INTEGRATION_FHIR_INTEGRATION_ENABLED=false
INTEGRATION_FHIR_INTEGRATION_URL=
INTEGRATION_FHIR_INTEGRATION_AUTH_TYPE=bearer
INTEGRATION_FHIR_INTEGRATION_AUTH_TOKEN=
INTEGRATION_FHIR_INTEGRATION_SYNC_INTERVAL_MINUTES=15
INTEGRATION_FHIR_INTEGRATION_TIMEOUT_SECONDS=20
INTEGRATION_FHIR_INTEGRATION_RETRY_COUNT=1
INTEGRATION_FHIR_INTEGRATION_RETRY_BACKOFF_SECONDS=2
INTEGRATION_FHIR_INTEGRATION_RESOURCE_SET=Patient,Encounter,Procedure,Consent

INTEGRATION_EPIC_EMR_ENABLED=false
INTEGRATION_EPIC_EMR_URL=
INTEGRATION_EPIC_EMR_SYNC_INTERVAL_MINUTES=30
INTEGRATION_EPIC_EMR_TIMEOUT_SECONDS=30

INTEGRATION_CERNER_MILLENNIUM_ENABLED=false
INTEGRATION_CERNER_MILLENNIUM_URL=
INTEGRATION_CERNER_MILLENNIUM_SYNC_INTERVAL_MINUTES=30
INTEGRATION_CERNER_MILLENNIUM_TIMEOUT_SECONDS=30

# ── Integration SLA thresholds ────────────────────────────────────────
INTEGRATION_SLA_MAX_SYNC_DELAY_SECONDS=3600
INTEGRATION_SLA_MAX_FAILURE_RATE=0.5
INTEGRATION_SLA_MAX_QUEUE_TIME_SECONDS=300
INTEGRATION_SLA_FAILURE_RATE_WINDOW=10

# ── Feature Flags ─────────────────────────────────────────────────────
# All flags default to safe values. Override only in non-production environments
# until the capability is validated and approved for pilot/GA.

# Signature & External Providers
FF_ENABLE_EXTERNAL_SIGNATURES=false
FF_ENABLE_SECURE_SIGNING_LINKS=false
ENABLE_TABLET_SIGNATURE=true
ENABLE_BIOMETRIC_SIGNATURE=false

# AI & Knowledge Layer
FF_ENABLE_AI_ASSIST=true
ENABLE_CLINICAL_AI_ASSISTANT=false
FF_ENABLE_SPECIALTY_PROMPTS=true
FF_ENABLE_PROCEDURE_KNOWLEDGE_BASE=true

# Audit & Evidence
FF_ENABLE_TIMELINE_AUDIT=true
FF_ENABLE_EVIDENCE_PACKAGES=true
FF_ENABLE_AUDIT_CHAIN=true

# Governance
FF_ENABLE_GOVERNANCE_WORKFLOW=true
FF_ENABLE_PROMPT_GOVERNANCE=true

# Procedure & Knowledge
FF_ENABLE_PROCEDURE_LIBRARY=true
FF_ENABLE_RISK_ENGINE=true

# EMR & Integrations
FF_ENABLE_EMR_MAPPING=false
FF_ENABLE_TRAKCARE_LIVE=false
FF_ENABLE_WEBHOOKS=true
FF_ENABLE_ANALYTICS=true
FF_ENABLE_BACKGROUND_JOBS=false

# PDF & Document Pipeline
FF_ENABLE_PDF_QR_CODE=true
FF_ENABLE_PDF_WATERMARK=true
FF_ENABLE_BILINGUAL_PDF=true
ENABLE_DYNAMIC_CONSENT_ENGINE=false
FF_ENABLE_CONTENT_MAPPING_ENGINE=false

# Clinical Content Platform V2
FF_ENABLE_CLINICAL_CONTENT_PLATFORM_V2=false
FF_ENABLE_APPROVED_FORMS_V2=false
FF_ENABLE_DOCTOR_WORKSPACE_V2=false
FF_ENABLE_CLINICAL_CONTENT_ENGINE=false
FF_ENABLE_PROCEDURE_MAPPING_ENGINE_V2=false
FF_ENABLE_PATIENT_EDUCATION_ENGINE=false
FF_ENABLE_DYNAMIC_CONSENT_GENERATOR=false
FF_ENABLE_CLINICAL_DECISION_SUPPORT=false

# Clinical Knowledge Engine MVP
FF_ENABLE_CLINICAL_KNOWLEDGE_ENGINE=false
FF_ENABLE_CKE_PROCEDURE_CATALOG=false
FF_ENABLE_CKE_PACKAGE_ASSEMBLY=false
FF_ENABLE_CKE_DECISION_RULES=false
FF_ENABLE_CKE_INFORMED_CONSENT_UI=false
FF_ENABLE_CKE_GOVERNANCE_UI=false

# Legal & Compliance
FF_ENABLE_PDPL_NOTICES=true
FF_ENABLE_LEGAL_HOLD=true
FF_ENABLE_RETENTION_POLICY=false
ENABLE_MODULE_SERVICE_ISOLATION=false
