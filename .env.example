# ── Database ─────────────────────────────────────────────────────────────────
# Option A (preferred for cloud DBs like Neon / Railway / Supabase):
#   Set DATABASE_URL and leave the DB_* vars empty.
# Option B (local / self-hosted Postgres):
#   Leave DATABASE_URL empty and fill in the DB_* vars below.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Used only when DATABASE_URL is not set:
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wathiqcare

# ── Backend auth / JWT ────────────────────────────────────────────────────────
JWT_SECRET_KEY="replace-with-a-long-random-string-min-32-chars"
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Optional feature flags ────────────────────────────────────────────────────
SHC_COMPLIANCE_MODULE=false

# ── Integration env vars (HIS / FHIR / DocuWare / SharePoint / ERP) ──────────
HIS_BASE_URL=""
FHIR_BASE_URL=""
DOCUWARE_BASE_URL=""
SHAREPOINT_SITE_URL=""
ERP_BASE_URL=""

# ── Frontend → Backend (server-side proxy helpers & Next.js API routes) ───────
# Production value: https://api.watiqcare.online
BACKEND_API_BASE_URL="https://api.watiqcare.online"
BACKEND_URL="https://api.watiqcare.online"

# ── Frontend public env vars (embedded into the browser bundle) ───────────────
# Production value: https://watiqcare.online
NEXT_PUBLIC_APP_URL="https://watiqcare.online"
# Leave empty to use same-origin Next.js API routes as the proxy layer.
NEXT_PUBLIC_API_BASE_URL=""
