# apps/api/.env.example — Python FastAPI backend
# Copy to apps/api/.env and fill real values.

APP_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wathiqcare
REDIS_URL=redis://localhost:6379/0

# Security
JWT_SECRET_KEY=change_me_very_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
PUBLIC_LINK_TOKEN_PEPPER=change_me_pepper_secret
OTP_SECRET=change_me_otp_secret

# SMS Provider: taqnyat | mock
SMS_PROVIDER=taqnyat
SMS_BASE_URL=https://api.taqnyat.sa/v1/messages
SMS_BEARER_TOKEN=REPLACE_WITH_REAL_TOKEN
SMS_SENDER=IMC
SMS_ENABLED=true
# Legacy keys kept for reference
TAQNYAT_API_KEY=
UNIFONIC_API_KEY=
SMS_SENDER_ID=WathiqCare

# Email (Microsoft Graph)
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_SENDER_EMAIL=noreply@wathiqcare.med.sa

# Object Storage
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=me-south-1
S3_BUCKET=wathiqcare-documents
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Payment Provider: hyperpay | stripe | mock
PAYMENT_PROVIDER=mock
HYPERPAY_ACCESS_TOKEN=
HYPERPAY_ENTITY_ID=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
