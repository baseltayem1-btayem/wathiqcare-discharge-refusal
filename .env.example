# WathiqCare environment template
# Copy and split values as needed for:
# - local root .env
# - apps/web/.env.local (web-facing keys)
# - apps/api/.env (backend keys)

# Core URLs
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000
BACKEND_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Database
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wathiqcare
DATABASE_URL=postgresql://postgres:change-me@localhost:5432/wathiqcare

# Security and auth
JWT_SECRET_KEY=replace-with-strong-random-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=wathiqcare
ACCESS_TOKEN_EXPIRE_MINUTES=60
PUBLIC_LINK_TOKEN_PEPPER=change_me_pepper_secret
OTP_SECRET=change_me_otp_secret
AUTH_COOKIE_NAME=wathiqcare_access_token
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_DOMAIN=

# CORS
CORS_ALLOW_ORIGINS=http://localhost:3000,https://wathiqcare.online

# Platform admin bootstrap
IMC_ADMIN_PASSWORD=
WATHIQCARE_ADMIN_PASSWORD=
DEMO_OWNER_PASSWORD_HASH=
PLATFORM_ADMIN_PASSWORD_HASH=
PLATFORM_SUPERUSER_PASSWORD_HASH=

# Microsoft Graph / SMTP-related provider keys
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_SENDER_EMAIL=

# SMS providers
SMS_PROVIDER=mock
TAQNYAT_API_KEY=
UNIFONIC_API_KEY=
SMS_SENDER_ID=WathiqCare

# Integrations and scheduler
INTEGRATION_SCHEDULER_ENABLED=true
INTEGRATION_SCHEDULER_POLL_SECONDS=15
INTEGRATION_SCHEDULER_STALE_RUN_SECONDS=600
INTEGRATION_ALERTS_ENABLED=true
INTEGRATION_ALERT_COOLDOWN_SECONDS=900
INTEGRATION_ALERT_REPEATED_FAILURE_THRESHOLD=3
INTEGRATION_ALERT_EMAIL_TO=
INTEGRATION_ALERT_WEBHOOK_URL=
INTEGRATION_ALERT_WEBHOOK_TIMEOUT_SECONDS=10
INTEGRATION_SLA_MAX_SYNC_DELAY_SECONDS=3600
INTEGRATION_SLA_MAX_FAILURE_RATE=0.5
INTEGRATION_SLA_MAX_QUEUE_TIME_SECONDS=300
INTEGRATION_SLA_FAILURE_RATE_WINDOW=10

# Optional object storage
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Optional Redis/queues
REDIS_URL=redis://localhost:6379/0

# Web dev convenience
NEXT_PUBLIC_ENABLE_DEV_LOGIN_PREFILL=false
NEXT_PUBLIC_DEV_LOGIN_EMAIL=
NEXT_PUBLIC_DEV_LOGIN_PASSWORD=
