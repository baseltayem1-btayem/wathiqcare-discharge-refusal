{
  "name": "@wathiqcare/web",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run prisma:generate && node ../../scripts/write-release-build-info.mjs && node scripts/run-sql-migrations.cjs && next build --webpack && node scripts/write-deterministic-routes-manifest.cjs",
    "start": "next start",
    "runtime:pre-vercel": "node scripts/pre-vercel-deploy-check.mjs",
    "validate:prod-release": "node scripts/prod-release-gate.cjs",
    "demo:seed": "node scripts/seed-demo-users.mjs",
    "uat:seed": "node scripts/seed-uat-users.mjs",
    "uat:diagnose": "node scripts/diagnose-uat-accounts.mjs",
    "uat:diagnose:apply": "node scripts/diagnose-uat-accounts.mjs --apply",
    "auth:ensure-user": "tsx -r dotenv/config scripts/ensure-auth-user.ts",
    "lint": "eslint",
    "check:lightningcss-native": "node -e \"require('lightningcss'); console.log('lightningcss native package loaded')\"",
    "test": "tsx --test src/lib/server/*.test.ts src/components/cases/*.test.ts src/lib/server/clinical-knowledge/**/*.test.ts src/lib/config/feature-flags.test.ts",
    "test:promissory-pdf": "tsx --tsconfig tsconfig.json --test src/lib/server/promissory-note-pdf.test.ts",
    "prisma:generate": "npx prisma generate --schema=./prisma/schema.prisma",
    "seed:clinical-knowledge": "tsx -r dotenv/config scripts/seed-clinical-knowledge.ts",
    "verify:clinical-knowledge": "tsx scripts/verify-clinical-knowledge.ts",
    "admin:reset-password": "tsx -r dotenv/config scripts/admin-reset-password.ts",
    "db:probe:runtime": "node scripts/db-probe-runtime.cjs",
    "db:probe:migration": "node scripts/db-probe-migration.cjs",
    "validate:live:3111": "node scripts/live-validation-3111.cjs",
    "validate:pilot-uat": "node scripts/validate-pilot-uat-readiness.mjs",
    "db:backfill:missing-tables": "npx prisma db execute --schema=./prisma/schema.prisma --file=./prisma/migrations/0014_production_backfill_missing_tables.sql",
    "test:magic-link": "node --test --experimental-strip-types src/lib/server/magic-link-route-flow.test.mjs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@fontsource/ibm-plex-sans-arabic": "^5.2.9",
    "@fontsource/tajawal": "^5.2.7",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-accordion": "^1.2.13",
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-aspect-ratio": "^1.1.9",
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-collapsible": "^1.1.13",
    "@radix-ui/react-context-menu": "^2.3.0",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-hover-card": "^1.1.16",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-menubar": "^1.1.17",
    "@radix-ui/react-navigation-menu": "^1.2.15",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-radio-group": "^1.4.0",
    "@radix-ui/react-scroll-area": "^1.2.11",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slider": "^1.4.0",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-toggle": "^1.1.11",
    "@radix-ui/react-toggle-group": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@sparticuz/chromium": "^138.0.2",
    "archiver": "^6.0.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "jsrsasign": "^11.1.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200",
    "puppeteer": "^24.42.0",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-day-picker": "8.10.2",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.80.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.1",
    "signature_pad": "^5.1.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/jsrsasign": "^10.5.15",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "fontkit": "^2.0.4",
    "madge": "^8.0.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.10",
    "prisma": "6.19.2",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "wawoff2": "^2.0.1"
  }
}
