{
  "name": "wathiqcare",
  "private": true,
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "overrides": {
    "effect": "^3.20.0",
    "defu": "^6.1.5"
  },
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "build": "npm run build -w apps/web",
    "start": "npm run start -w apps/web",
    "lint": "npm run lint -w apps/web",
    "validate:promissory-pdf": "npm run test:promissory-pdf -w apps/web && npm run lint -w apps/web && npm run build -w apps/web",
    "prisma:generate": "npm run prisma:generate -w apps/web",
    "runtime:init-db": "node scripts/init-database.mjs",
    "runtime:validate-staging": "node scripts/validate-staging.mjs",
    "runtime:test-db": "node scripts/test-db-runtime.mjs",
    "runtime:security-audit": "node scripts/security-env-audit.mjs",
    "runtime:pre-vercel": "node scripts/pre-vercel-deploy-check.mjs",
    "runtime:certify-staging": "node scripts/staging-readiness-certification.mjs",
    "admins:ensure": "node prisma/ensure-admin-access.js",
    "validate:pilot-uat": "npm run validate:pilot-uat -w apps/web",
    "uat:biometric-local-agent": "node scripts/uat/digitalpersona-local-agent-stub.mjs",
    "audit:language": "npx tsx scripts/language-audit/runAll.ts",
    "audit:language:gate": "npx tsx scripts/language-audit/ciGate.ts",
    "uat:full-consent": "npx tsx scripts/uat/run-full-consent-uat.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.2",
    "postcss": "^8.5.10",
    "prisma": "^6.19.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.22.3"
  }
}
