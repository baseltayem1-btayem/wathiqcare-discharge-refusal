NODE_ENV=development
PORT=4000
API_PREFIX=api
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/wathiqcare_backend
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REDIS_URL=redis://localhost:6380
S3_ENDPOINT=http://localhost:9002
S3_REGION=us-east-1
S3_BUCKET=wathiqcare-docs
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
DEFAULT_TENANT_CODE=wathiq-hospital
# Comma-separated origins for direct-browser calls (prod should be explicit)
# Example: https://app.hospital.example,https://portal.hospital.example
CORS_ALLOWED_ORIGINS=

# Startup hardening
# true => fail startup if /api/health/ready is not healthy at boot
STARTUP_STRICT_READINESS=false

# OTP hardening
# false in production to avoid weak in-memory OTP behavior
OTP_ALLOW_INMEMORY_FALLBACK=true

# Upload hardening
MAX_UPLOAD_FILE_SIZE_BYTES=20971520
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,image/png,image/jpeg,text/plain,application/vnd.openxmlformats-officedocument.wordprocessingml.document
