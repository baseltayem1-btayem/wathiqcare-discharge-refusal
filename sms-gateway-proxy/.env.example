# SMS Gateway Proxy — Environment Configuration Template
# Copy this file to .env and fill in all required values.
# NEVER commit .env to source control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Taqnyat API ───────────────────────────────────────────────────────────────
# The Taqnyat API endpoint. Use the production URL unless instructed otherwise.
TAQNYAT_API_URL=https://api.taqnyat.sa/v1

# Your Taqnyat bearer token. This is held ONLY in the proxy.
# WathiqCare never sees this token.
TAQNYAT_BEARER_TOKEN=your_taqnyat_bearer_token_here

# Default sender name registered with Taqnyat.
TAQNYAT_SENDER=WathiqCare

# ── WathiqCare Shared Secret ──────────────────────────────────────────────────
# This secret is shared between WathiqCare and the proxy only.
# Generate with: ./scripts/generate-secret.sh
WATHIQCARE_SMS_PROXY_SECRET=your_generated_secret_here

# ── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=production
