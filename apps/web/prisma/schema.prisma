generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanCode {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  PAUSED
  CANCELED
  EXPIRED
}

enum MembershipRole {
  OWNER
  ADMIN
  MANAGER
  BILLING
  MEMBER
  VIEWER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
  REMOVED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum TenantRoleStatus {
  ACTIVE
  INACTIVE
}

enum UserType {
  PLATFORM_ADMIN
  TENANT_ADMIN
  TENANT_USER
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  ARCHIVED
}

enum CaseType {
  GENERAL
  DISCHARGE_REFUSAL
}

enum DocumentType {
  CASE_FILE
  DISCHARGE_REFUSAL_FORM
  FINANCIAL_RESPONSIBILITY_NOTICE
  OTHER
}

enum DocumentStatus {
  DRAFT
  GENERATED
  SIGNED
  ARCHIVED
}

enum UsageMetric {
  ACTIVE_USERS
  CASES
  DOCUMENTS
  STORAGE_BYTES
  API_REQUESTS
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum SubscriptionEventType {
  CREATED
  UPDATED
  RENEWED
  CANCELED
  PAST_DUE
  PLAN_CHANGED
  SEAT_CHANGED
  PAYMENT_FAILED
  PAYMENT_SUCCEEDED
}

enum FeatureFlagScope {
  GLOBAL
  TENANT
  MODULE
}

enum OperationDepartment {
  PHARMACY
  NURSING
  LEGAL
  LABORATORY
  RADIOLOGY
  CASE_MANAGEMENT
  PATIENT_RELATIONS
  BILLING_INSURANCE
  ADMIN_MEDICAL_DIRECTOR
}

enum OperationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum SlaState {
  ON_TRACK
  AT_RISK
  BREACHED
}

enum EscalationLevel {
  NONE
  SUPERVISOR
  MANAGER
  DIRECTOR
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum DataClassification {
  PATIENT_SENSITIVE
  OPERATIONAL
  AUDIT_LOG
  ANALYTICS
  BACKUP
}

enum ResidencyScope {
  KSA_ONLY
  CONTROLLED_EXPORT
  GLOBAL_NON_PERSONAL
}

enum ConsentMethod {
  ELECTRONIC_SIGNATURE
  OTP
  WITNESS_ACKNOWLEDGMENT
  WRITTEN
}

enum ConsentTemplateStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  ACTIVE
  RETIRED
  ARCHIVED
}

enum ConsentDocumentStatus {
  DRAFT
  AI_DRAFT
  PHYSICIAN_REVIEW
  APPROVED
  READY_FOR_SIGNATURE
  SIGNED
  FINALIZED
  ARCHIVED
  VOID
}

enum ConsentSectionKind {
  FIXED_LEGAL
  DYNAMIC_MEDICAL
  AUTO_POPULATED
  SIGNATURE
  WITNESS
  INTERPRETER
}

enum ConsentSignatureRole {
  PATIENT
  PHYSICIAN
  WITNESS
  INTERPRETER
  GUARDIAN
}

enum ConsentRiskClass {
  COMMON
  LESS_COMMON
  RARE
  SERIOUS
  LIFE_THREATENING
}

enum ConsentRiskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ConsentAlertLevel {
  INFO
  WARNING
  HIGH_ALERT
  LEGAL_CRITICAL
}

enum ConsentCommitteeType {
  LEGAL
  MEDICAL
  QUALITY
  COMPLIANCE
}

enum ConsentReviewDecision {
  PENDING
  APPROVED
  CHANGES_REQUESTED
  REJECTED
}

enum ConsentEvidenceCopyType {
  PATIENT_COPY
  MEDICAL_RECORD_COPY
  LEGAL_ARCHIVE_COPY
}

enum ProcedureEducationStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProcedureEducationAssetType {
  IMAGE
  VIDEO
  PDF
}

enum ProcedureEducationAuditAction {
  VIEWED
}

enum PromissoryNoteStatus {
  DRAFT
  ACTIVE
  SETTLED
  VOID
  OVERDUE
}

enum DsrRequestType {
  ACCESS
  CORRECTION
  DELETION
  RESTRICTION_OBJECTION
  EXPORT
}

enum DsrRequestStatus {
  REQUESTED
  IDENTITY_VERIFIED
  LEGAL_REVIEW
  APPROVED
  REJECTED
  EXECUTED
  CLOSED
}

enum RetentionActionStatus {
  PENDING
  LEGAL_HOLD
  BLOCKED
  APPROVED
  EXECUTED
  CANCELED
}

enum LegalReadinessStatus {
  COMPLIANT
  WARNING
  BLOCKED
}

enum IncidentSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum IncidentStatus {
  DETECTED
  TRIAGED
  CONTAINED
  REMEDIATED
  RECOVERED
  CLOSED
}

enum BackupJobStatus {
  SCHEDULED
  RUNNING
  SUCCEEDED
  FAILED
  VERIFIED
}

enum SubscriberModuleAccessStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  TRIAL
}

model Tenant {
  id           String   @id @default(uuid())
  name         String
  code         String   @unique
  domain       String?
  authConfig   Json     @default("{\"password_enabled\":true,\"microsoft_sso_enabled\":false,\"secure_link_enabled\":false}") @map("auth_config")
  isActive     Boolean  @default(true) @map("is_active")
  isPlatform   Boolean  @default(false) @map("is_platform")
  timezone     String?  @default("UTC")
  country      String?
  billingEmail String?  @map("billing_email")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  users                               User[]                               @relation("PrimaryTenantUsers")
  memberships                         TenantMembership[]
  invitations                         Invitation[]
  subscriptions                       Subscription[]
  cases                               Case[]
  dischargeRefusalCases               DischargeRefusalCase[]
  homeCarePlans                       HomeCarePlan[]
  equipmentRequests                   EquipmentRequest[]
  transferRequests                    TransferRequest[]
  patientFinancialLiabilities         PatientFinancialLiability[]
  documents                           Document[]
  auditLogs                           AuditLog[]
  usageRecords                        UsageRecord[]
  invoices                            Invoice[]
  subscriptionEvents                  SubscriptionEvent[]
  subscriberModuleAccesses            SubscriberModuleAccess[]
  caseOperationStates                 CaseOperationState[]
  caseAssignmentHistory               CaseAssignmentHistory[]
  caseStepEvents                      CaseStepEvent[]
  operationNotifications              OperationNotification[]
  departmentSlaConfigs                DepartmentSlaConfig[]
  departments                         Department[]
  tenantRoles                         TenantRole[]
  roleAssignments                     UserRoleAssignment[]
  allowedDomains                      TenantAllowedDomain[]
  branding                            TenantBranding?
  dashboardAlerts                     DashboardAlert[]
  notificationDeliveryAttempts        NotificationDeliveryAttempt[]
  alertAcknowledgments                AlertAcknowledgment[]
  notificationSettings                TenantNotificationSetting?
  consentRecords                      ConsentRecord[]
  dataSubjectRequests                 DataSubjectRequest[]
  retentionPolicies                   RetentionPolicy[]
  retentionActions                    RetentionAction[]
  legalReadinessChecks                LegalReadinessCheck[]
  auditChainEvents                    AuditChainEvent[]
  securityIncidents                   SecurityIncident[]
  backupJobs                          BackupJob[]
  backupRestoreTests                  BackupRestoreTest[]
  reportAccessLogs                    ReportAccessLog[]
  dataResidencyRules                  DataResidencyRule[]
  tenantSecuritySettings              TenantSecuritySetting?
  privilegedAccessLogs                PrivilegedAccessLog[]
  promissoryNotes                     PromissoryNote[]
  consentCategories                   ConsentCategory[]
  consentTemplates                    ConsentTemplate[]
  consentTemplateVersions             ConsentTemplateVersion[]
  consentTemplateSections             ConsentTemplateSection[]
  consentAIPrompts                    ConsentAIPrompt[]
  consentDocuments                    ConsentDocument[]
  consentDocumentSections             ConsentDocumentSection[]
  consentDocumentSignatures           ConsentDocumentSignature[]
  consentAuditEvents                  ConsentAuditEvent[]
  consentPromptRegistry               ConsentPromptRegistry[]
  consentWordingRepository            ConsentWordingRepository[]
  consentProcedureCatalog             ConsentProcedureCatalog[]
  consentProcedureRiskItems           ConsentProcedureRiskItem[]
  consentProcedureAlternatives        ConsentProcedureAlternative[]
  consentProcedureRefusalConsequences ConsentProcedureRefusalConsequence[]
  consentProcedureOutcomes            ConsentProcedureOutcome[]
  consentDocumentRisks                ConsentDocumentRisk[]
  consentGeneratedParagraphs          ConsentGeneratedParagraph[]
  consentTimelineEvents               ConsentTimelineEvent[]
  consentCommitteeReviews             ConsentCommitteeReview[]
  consentEvidencePackages             ConsentEvidencePackage[]
  evidencePackages                    EvidencePackage[]
  evidenceEvents                      EvidenceEvent[]
  evidenceTimelines                   EvidenceTimeline[]
  evidenceAssetRecords                EvidenceAssetRecord[]
  consentEmrMappings                  ConsentEmrMapping[]
  trakCareIntegrationLogs             TrakCareIntegrationLog[]
  patientExternalReferences           PatientExternalReference[]
  encounterExternalReferences         EncounterExternalReference[]
  consentSourceSnapshots              ConsentSourceSnapshot[]
  procedureEducation                  ProcedureEducation[]
  procedureEducationVersions          ProcedureEducationVersion[]
  procedureEducationSections          ProcedureEducationSection[]
  procedureEducationAssets            ProcedureEducationAsset[]
  procedureEducationLocalizations     ProcedureEducationLocalization[]
  procedureEducationAuditEvents       ProcedureEducationAuditEvent[]
  featureFlagOverrides                FeatureFlagOverride[]
  clinicalSpecialties                 ClinicalSpecialty[]
  clinicalProcedures                  ClinicalProcedure[]
  clinicalKnowledgePackages           ClinicalKnowledgePackage[]
  clinicalKnowledgeIllustrations      ClinicalKnowledgeIllustration[]
  clinicalConsentForms                ConsentForm[]
  clinicalConsentFormSections         ConsentFormSection[]
  clinicalEducationMaterials          EducationMaterial[]
  clinicalRiskDisclosures             RiskDisclosure[]
  clinicalDecisionRules               DecisionRule[]
  clinicalGovernanceEvents            GovernanceEvent[]

  @@map("tenants")
}

model FeatureFlagOverride {
  id        String           @id @default(uuid())
  scope     FeatureFlagScope
  scopeRef  String           @map("scope_ref")
  key       String
  value     Boolean
  tenantId  String?          @map("tenant_id")
  moduleKey String?          @map("module_key")
  updatedBy String?          @map("updated_by")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([scope, scopeRef, key])
  @@index([tenantId, moduleKey, key])
  @@map("feature_flag_overrides")
}

model SubscriberModuleAccess {
  id               String                       @id @default(uuid())
  subscriberId     String                       @map("subscriber_id")
  moduleKey        String                       @map("module_key")
  status           SubscriberModuleAccessStatus @default(INACTIVE)
  activatedBy      String?                      @map("activated_by")
  activatedAt      DateTime?                    @map("activated_at")
  deactivatedBy    String?                      @map("deactivated_by")
  deactivatedAt    DateTime?                    @map("deactivated_at")
  subscriptionPlan String?                      @map("subscription_plan")
  expiryDate       DateTime?                    @map("expiry_date")
  notes            String?
  createdAt        DateTime                     @default(now()) @map("created_at")
  updatedAt        DateTime                     @updatedAt @map("updated_at")

  subscriber Tenant @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@unique([subscriberId, moduleKey], map: "uq_subscriber_module_access_subscriber_module")
  @@index([subscriberId, status], map: "idx_subscriber_module_access_subscriber_status")
  @@index([moduleKey, status], map: "idx_subscriber_module_access_module_status")
  @@map("subscriber_module_access")
}

model TenantBranding {
  id                           String   @id
  tenantId                     String   @unique @map("tenant_id")
  displayName                  String?  @map("display_name")
  legalName                    String?  @map("legal_name")
  licenseNumber                String?  @map("license_number")
  commercialRegistrationNumber String?  @map("commercial_registration_number")
  taxNumber                    String?  @map("tax_number")
  contactEmail                 String?  @map("contact_email")
  contactPhone                 String?  @map("contact_phone")
  addressLine1                 String?  @map("address_line1")
  addressLine2                 String?  @map("address_line2")
  city                         String?
  country                      String?
  postalCode                   String?  @map("postal_code")
  websiteUrl                   String?  @map("website_url")
  logoUrl                      String?  @map("logo_url")
  documentHeaderText           String?  @map("document_header_text")
  documentFooterText           String?  @map("document_footer_text")
  legalDisclaimer              String?  @map("legal_disclaimer")
  createdAt                    DateTime @default(now()) @map("created_at")
  updatedAt                    DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("tenant_branding")
}

model TenantAllowedDomain {
  id        String   @id
  tenantId  String   @map("tenant_id")
  domain    String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, domain])
  @@index([domain])
  @@map("tenant_allowed_domains")
}

model Plan {
  id                String   @id @default(uuid())
  code              PlanCode @unique
  name              String
  description       String?
  priceMonthlyCents Int      @default(0) @map("price_monthly_cents")
  priceYearlyCents  Int      @default(0) @map("price_yearly_cents")
  seatLimit         Int      @default(5) @map("seat_limit")
  features          Json
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                     String             @id @default(uuid())
  tenantId               String             @map("tenant_id")
  planId                 String             @map("plan_id")
  status                 SubscriptionStatus @default(TRIALING)
  billingInterval        BillingInterval    @default(MONTHLY) @map("billing_interval")
  seatLimit              Int                @default(5) @map("seat_limit")
  trialEndsAt            DateTime?          @map("trial_ends_at")
  currentPeriodStart     DateTime           @map("current_period_start")
  currentPeriodEnd       DateTime           @map("current_period_end")
  cancelAt               DateTime?          @map("cancel_at")
  canceledAt             DateTime?          @map("canceled_at")
  externalCustomerId     String?            @map("external_customer_id")
  externalSubscriptionId String?            @map("external_subscription_id")
  metadata               Json?
  version                Int                @default(1)
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan     Plan                @relation(fields: [planId], references: [id], onDelete: Restrict)
  invoices Invoice[]
  events   SubscriptionEvent[]

  @@index([tenantId])
  @@index([status])
  @@map("subscriptions")
}

model User {
  id                     String    @id @default(uuid())
  tenantId               String    @map("tenant_id")
  email                  String    @unique
  fullName               String    @map("full_name")
  userType               UserType  @default(TENANT_USER) @map("user_type")
  role                   String
  status                 String    @default("active")
  isActive               Boolean   @default(true) @map("is_active")
  emailVerified          Boolean   @default(false) @map("email_verified")
  emailVerifiedAt        DateTime? @map("email_verified_at")
  hashedPassword         String?   @map("hashed_password")
  lastPasswordChangedAt  DateTime? @map("last_password_changed_at")
  passwordResetTokenHash String?   @map("password_reset_token_hash")
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at")
  authProvider           String    @default("local_magic") @map("auth_provider")
  failedLoginAttempts    Int       @default(0) @map("failed_login_attempts")
  lockedUntil            DateTime? @map("locked_until")
  lastLoginAt            DateTime? @map("last_login_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  primaryTenant                   Tenant                  @relation("PrimaryTenantUsers", fields: [tenantId], references: [id], onDelete: Cascade)
  memberships                     TenantMembership[]
  sentInvitations                 Invitation[]            @relation("InvitationSender")
  acceptedInvitations             Invitation[]            @relation("InvitationAcceptor")
  createdCases                    Case[]                  @relation("CaseCreator")
  updatedCases                    Case[]                  @relation("CaseUpdater")
  generatedDocuments              Document[]              @relation("DocumentGenerator")
  signedDocuments                 Document[]              @relation("DocumentSigner")
  auditLogs                       AuditLog[]
  ownedCaseOperationStates        CaseOperationState[]    @relation("CaseAssignedUser")
  caseAssignmentsByActor          CaseAssignmentHistory[] @relation("AssignmentActor")
  caseStepEventsByActor           CaseStepEvent[]         @relation("StepEventActor")
  operationNotifications          OperationNotification[] @relation("NotificationRecipient")
  operationNotificationsTriggered OperationNotification[] @relation("NotificationTrigger")
  roleAssignments                 UserRoleAssignment[]
  alertAcknowledgments            AlertAcknowledgment[]

  @@index([tenantId])
  @@map("users")
}

model Department {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  code      String
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("departments")
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  module      String
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rolePermissions TenantRolePermission[]

  @@index([module, isActive])
  @@map("permissions")
}

model TenantRole {
  id               String           @id @default(uuid())
  tenantId         String           @map("tenant_id")
  code             String
  name             String
  description      String?
  status           TenantRoleStatus @default(ACTIVE)
  isTemplate       Boolean          @default(false) @map("is_template")
  clonedFromRoleId String?          @map("cloned_from_role_id")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions TenantRolePermission[]
  users       UserRoleAssignment[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@map("tenant_roles")
}

model TenantRolePermission {
  id           String   @id @default(uuid())
  tenantRoleId String   @map("tenant_role_id")
  permissionId String   @map("permission_id")
  allowed      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenantRole TenantRole @relation(fields: [tenantRoleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([tenantRoleId, permissionId])
  @@index([permissionId])
  @@map("tenant_role_permissions")
}

model UserRoleAssignment {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  userId       String   @map("user_id")
  tenantRoleId String   @map("tenant_role_id")
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantRole TenantRole @relation(fields: [tenantRoleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, tenantRoleId])
  @@index([tenantId, userId])
  @@index([tenantId, tenantRoleId])
  @@map("user_role_assignments")
}

model TenantMembership {
  id          String           @id @default(uuid())
  tenantId    String           @map("tenant_id")
  userId      String           @map("user_id")
  role        MembershipRole
  status      MembershipStatus @default(ACTIVE)
  joinedAt    DateTime         @default(now()) @map("joined_at")
  invitedAt   DateTime?        @map("invited_at")
  suspendedAt DateTime?        @map("suspended_at")
  metadata    Json?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId, status])
  @@map("tenant_memberships")
}

model Invitation {
  id               String           @id @default(uuid())
  tenantId         String           @map("tenant_id")
  email            String
  role             MembershipRole
  status           InvitationStatus @default(PENDING)
  token            String           @unique
  expiresAt        DateTime         @map("expires_at")
  invitedByUserId  String           @map("invited_by_user_id")
  acceptedByUserId String?          @map("accepted_by_user_id")
  acceptedAt       DateTime?        @map("accepted_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy  User   @relation("InvitationSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  acceptedBy User?  @relation("InvitationAcceptor", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([email])
  @@map("invitations")
}

model Case {
  id              String     @id @default(uuid())
  tenantId        String     @map("tenant_id")
  caseNumber      String?    @map("case_number")
  caseType        CaseType   @default(GENERAL) @map("case_type")
  title           String?
  status          CaseStatus @default(OPEN)
  workflowType    String?    @map("workflow_type")
  patientName     String?    @map("patient_name")
  patientIdNumber String?    @map("patient_id_number")
  medicalRecordNo String?    @map("medical_record_no")
  roomNumber      String?    @map("room_number")
  createdByUserId String?    @map("created_by_user_id")
  updatedByUserId String?    @map("updated_by_user_id")
  closedAt        DateTime?  @map("closed_at")
  metadata        Json?
  version         Int        @default(1)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  tenant                      Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy                   User?                       @relation("CaseCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy                   User?                       @relation("CaseUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  documents                   Document[]
  auditLogs                   AuditLog[]
  dischargeRefusalCases       DischargeRefusalCase[]
  homeCarePlans               HomeCarePlan[]
  equipmentRequests           EquipmentRequest[]
  transferRequests            TransferRequest[]
  patientFinancialLiabilities PatientFinancialLiability[]
  operationState              CaseOperationState?
  assignmentHistory           CaseAssignmentHistory[]
  stepEvents                  CaseStepEvent[]
  notifications               OperationNotification[]
  consentRecords              ConsentRecord[]
  dataSubjectRequests         DataSubjectRequest[]
  retentionActions            RetentionAction[]
  legalReadinessChecks        LegalReadinessCheck[]
  auditChainEvents            AuditChainEvent[]
  securityIncidents           SecurityIncident[]
  reportAccessLogs            ReportAccessLog[]
  privilegedAccessLogs        PrivilegedAccessLog[]
  promissoryNotes             PromissoryNote[]
  consentDocuments            ConsentDocument[]
  evidencePackages            EvidencePackage[]
  evidenceEvents              EvidenceEvent[]
  evidenceTimelines           EvidenceTimeline[]
  patientExternalReferences   PatientExternalReference[]
  encounterExternalReferences EncounterExternalReference[]
  trakCareIntegrationLogs     TrakCareIntegrationLog[]

  @@unique([tenantId, caseNumber])
  @@index([tenantId, status])
  @@map("cases")
}

model PromissoryNote {
  id              String               @id @default(uuid())
  tenantId        String               @map("tenant_id")
  caseId          String               @map("case_id")
  noteNumber      String               @map("note_number")
  debtorName      String               @map("debtor_name")
  debtorIdNumber  String?              @map("debtor_id_number")
  issuerName      String?              @map("issuer_name")
  amount          Decimal              @db.Decimal(12, 2)
  currency        String               @default("SAR")
