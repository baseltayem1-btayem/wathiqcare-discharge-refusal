# WathiqCare Online — PRODUCTION Environment Configuration
# Date: May 14, 2026
# Status: Template for Authorized Users Only
# 🔐 CRITICAL: Store this file only in Vercel Secrets Manager or AWS Secrets Manager

# ═══════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION (Neon PostgreSQL HA)
# Production uses High-Availability cluster with PITR and automated backups
# ═══════════════════════════════════════════════════════════════════════════
# Pooled connection (for application runtime) - PRODUCTION
DATABASE_URL_POOLED=postgresql://neondb_owner:PASSWORD_HERE@wathiqcare-production.gwc.azure.neon.tech/wathiqcare_production?sslmode=require&channel_binding=require&pgbouncer=true&connection_limit=20

# Direct connection (for migrations only - use unpooled) - PRODUCTION
DATABASE_URL_UNPOOLED=postgresql://neondb_owner:PASSWORD_HERE@wathiqcare-production.gwc.azure.neon.tech/wathiqcare_production?sslmode=require&channel_binding=require

# Runtime fallback
DATABASE_URL=${DATABASE_URL_POOLED}

# ═══════════════════════════════════════════════════════════════════════════
# APPLICATION URLs
# ═══════════════════════════════════════════════════════════════════════════
BASE_URL=https://wathiqcare.online
NEXT_PUBLIC_API_BASE_URL=https://wathiqcare.online
NEXTAUTH_URL=https://wathiqcare.online
NODE_ENV=production
ENVIRONMENT=production

# ═══════════════════════════════════════════════════════════════════════════
# AUTHENTICATION & SECURITY (PRODUCTION)
# ═══════════════════════════════════════════════════════════════════════════
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=YOUR_PRODUCTION_NEXTAUTH_SECRET_HERE
JWT_SECRET_KEY=YOUR_PRODUCTION_JWT_SECRET_HERE
JWT_ALGORITHM=HS256
JWT_ISSUER=wathiqcare-production

# ═══════════════════════════════════════════════════════════════════════════
# MICROSOFT ENTRA ID (OAuth) - PRODUCTION
# ═══════════════════════════════════════════════════════════════════════════
MICROSOFT_TENANT_ID=08b4493f-d1e2-4c61-b46f-d652ad477fa6
MICROSOFT_CLIENT_ID=YOUR_PRODUCTION_MICROSOFT_CLIENT_ID
MICROSOFT_CLIENT_SECRET=YOUR_PRODUCTION_MICROSOFT_CLIENT_SECRET
MICROSOFT_SENDER_EMAIL=noreply@wathiqcare.onmicrosoft.com

# ═══════════════════════════════════════════════════════════════════════════
# EMAIL (SMTP) - PRODUCTION
# ═══════════════════════════════════════════════════════════════════════════
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=noreply@wathiqcare.onmicrosoft.com
SMTP_PASSWORD=YOUR_PRODUCTION_SMTP_PASSWORD
SMTP_FROM_NAME=WathiqCare
SMTP_FROM_EMAIL=noreply@wathiqcare.onmicrosoft.com

# ═══════════════════════════════════════════════════════════════════════════
# SMS (Taqnyat) - PRODUCTION
# ═══════════════════════════════════════════════════════════════════════════
SMS_PROVIDER=taqnyat
SMS_BASE_URL=https://api.taqnyat.sa
SMS_BEARER_TOKEN=YOUR_PRODUCTION_TAQNYAT_TOKEN
SMS_SENDER=WathiqCare
SMS_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════
# OBJECT STORAGE (AWS S3) - PRODUCTION
# ═══════════════════════════════════════════════════════════════════════════
STORAGE_PROVIDER=s3
STORAGE_ENV=production
S3_REGION=me-south-1
S3_BUCKET=wathiqcare-production-documents
S3_ACCESS_KEY=YOUR_PRODUCTION_S3_ACCESS_KEY
S3_SECRET_KEY=YOUR_PRODUCTION_S3_SECRET_KEY
S3_ENDPOINT=https://s3.me-south-1.amazonaws.com

# Production storage buckets
S3_PDF_BUCKET=wathiqcare-production-pdfs
S3_SIGNATURES_BUCKET=wathiqcare-production-signatures
S3_AUDIT_BUCKET=wathiqcare-production-audit
S3_REPORTS_BUCKET=wathiqcare-production-reports
S3_ATTACHMENTS_BUCKET=wathiqcare-production-attachments

# ═══════════════════════════════════════════════════════════════════════════
# LOGGING & DEBUGGING (PRODUCTION - Minimal)
# ═══════════════════════════════════════════════════════════════════════════
LOG_LEVEL=info
ENABLE_DETAILED_LOGGING=false
DEBUG_MODE=false

# ═══════════════════════════════════════════════════════════════════════════
# FEATURE FLAGS (ALL ENABLED IN PRODUCTION)
# ═══════════════════════════════════════════════════════════════════════════
ENABLE_INFORMED_CONSENTS=true
ENABLE_DISCHARGE_REFUSAL=true
ENABLE_PROMISSORY_NOTES=true
ENABLE_LEGAL_REVIEW=true
ENABLE_ESCALATION=true
ENABLE_DELEGATION=true
ENABLE_MULTI_ROLE_APPROVAL=true
ENABLE_CONDITIONAL_APPROVAL=true

# PDF Security (STRICT IN PRODUCTION)
ENABLE_PDF_SECURITY=true
PDF_DISABLE_EDITING=true
PDF_DISABLE_PRINTING=false

# Audit (STRICT IN PRODUCTION)
ENABLE_AUDIT_LOGGING=true
AUDIT_LOG_RETENTION_DAYS=2555
AUDIT_IMMUTABILITY_ENABLED=true
AUDIT_HASH_CHAINING_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════
# CORS & SECURITY (PRODUCTION)
# ═══════════════════════════════════════════════════════════════════════════
CORS_ALLOW_ORIGINS=https://wathiqcare.online
ENABLE_CSRF_PROTECTION=true
ENABLE_RATE_LIMITING=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
SESSION_TIMEOUT_MINUTES=60
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

# ═══════════════════════════════════════════════════════════════════════════
# MONITORING (PRODUCTION)
# ═══════════════════════════════════════════════════════════════════════════
SENTRY_DSN=https://YOUR_SENTRY_DSN@sentry.io/YOUR_PROJECT_ID
DATADOG_API_KEY=YOUR_DATADOG_API_KEY
DATADOG_APPLICATION_ID=YOUR_DATADOG_APP_ID

# ═══════════════════════════════════════════════════════════════════════════
# ADMIN CREDENTIALS (PRODUCTION - Use bcrypt hashes only)
# DO NOT store plain passwords. Generate hashes separately.
# ═══════════════════════════════════════════════════════════════════════════
PLATFORM_ADMIN_PASSWORD_HASH=$2b$10$YOUR_BCRYPT_HASH_HERE
PLATFORM_SUPERUSER_PASSWORD_HASH=$2b$10$YOUR_BCRYPT_HASH_HERE
