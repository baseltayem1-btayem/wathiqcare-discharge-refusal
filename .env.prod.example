# WathiqCare Production — Secrets & Configuration
# Used with: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# ⚠️  NEVER commit this file to source control.
# ⚠️  Generate secure random values for all secrets before first deployment.
#     Example: openssl rand -base64 48

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=wathiqcare
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=wathiqcare_backend
POSTGRES_PORT=5432

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
REDIS_PORT=6379

# ─── MinIO / Object Storage ───────────────────────────────────────────────────
S3_ACCESS_KEY=REPLACE_WITH_ACCESS_KEY
S3_SECRET_KEY=REPLACE_WITH_SECRET_KEY
S3_BUCKET=wathiqcare-docs
S3_REGION=us-east-1
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─── JWT Secrets ─────────────────────────────────────────────────────────────
# Minimum 32 characters. Generate: openssl rand -base64 48
JWT_ACCESS_SECRET=REPLACE_WITH_LONG_RANDOM_STRING_MIN_32_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_LONG_RANDOM_STRING_MIN_32_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Tenant ──────────────────────────────────────────────────────────────────
DEFAULT_TENANT_CODE=wathiq-hospital

# ─── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
NEXTAUTH_URL=https://wathiqcare.hospital

# ─── CORS (optional) ─────────────────────────────────────────────────────────
# Comma-separated allowed origins. Leave empty if backend is behind proxy only.
CORS_ALLOWED_ORIGINS=

# ─── Runtime Hardening ────────────────────────────────────────────────────────
STARTUP_STRICT_READINESS=true
OTP_ALLOW_INMEMORY_FALLBACK=false

# ─── Upload Policy ────────────────────────────────────────────────────────────
MAX_UPLOAD_FILE_SIZE_BYTES=20971520
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,image/png,image/jpeg,text/plain,application/vnd.openxmlformats-officedocument.wordprocessingml.document
