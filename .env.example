DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wathiqcare

# Prisma / Neon PostgreSQL
DATABASE_URL="postgresql://user:password@host/db?sslmode=require&channel_binding=require"

# Backend auth/JWT signing (must match token issuer)
JWT_SECRET_KEY="replace-with-strong-secret"
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Frontend -> backend integration (Next rewrites and server-side proxy helpers)
BACKEND_URL="https://api.example.com"
BACKEND_API_BASE_URL="https://api.example.com"

# Optional for browser-side API base if not using same-origin paths
NEXT_PUBLIC_API_BASE_URL=""

# Microsoft Graph email delivery
# The tenant/client/sender values are fixed by backend validation for this deployment.
MICROSOFT_TENANT_ID="08b4493f-d1e2-4c61-b46f-d652ad477fa6"
MICROSOFT_CLIENT_ID="d25f4d4d-51bf-4be8-b4fd-ce8744434eef"
MICROSOFT_CLIENT_SECRET="replace-with-microsoft-graph-client-secret"
MICROSOFT_SENDER_EMAIL="admin@wathiqcare.med.sa"
