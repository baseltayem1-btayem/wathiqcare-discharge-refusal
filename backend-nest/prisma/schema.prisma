  refusalCaseId    String    @map("refusal_case_id")
  reason           String
  active           Boolean   @default(true)
  createdByUserId  String    @map("created_by_user_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  releasedAt       DateTime? @map("released_at")
  releasedByUserId String?   @map("released_by_user_id")

  @@index([tenantId, refusalCaseId, active])
  @@map("legal_holds")
}

model RetentionPolicy {
  id              String          @id @default(uuid())
  tenantId        String?         @map("tenant_id")
  entityType      String          @map("entity_type")
  retentionDays   Int             @map("retention_days")
  deleteBehavior  DeleteBehavior  @map("delete_behavior")
  archiveBehavior ArchiveBehavior @map("archive_behavior")
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@unique([tenantId, entityType])
  @@index([tenantId, active])
  @@map("retention_policies")
}

model AuditLog {
  id                String   @id @default(uuid())
  tenantId          String   @map("tenant_id")
  entityType        String   @map("entity_type")
  entityId          String   @map("entity_id")
  action            String
  actorUserId       String?  @map("actor_user_id")
  actorEmail        String?  @map("actor_email")
  actorRoleSnapshot String?  @map("actor_role_snapshot")
  ipAddress         String?  @map("ip_address")
  userAgent         String?  @map("user_agent")
  beforeJson        Json?    @map("before_json")
  afterJson         Json?    @map("after_json")
  metadataJson      Json?    @map("metadata_json")
  occurredAt        DateTime @default(now()) @map("occurred_at")

  @@index([tenantId, occurredAt])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, action])
  @@map("audit_logs")
}

model AccessLog {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  userId           String   @map("user_id")
